#!/bin/bash
# 自动生成的环境构建脚本 
# 此脚本将基于官方的基础镜像构建带有完整环境的评测镜像。

# 切换到执行环境的项目根目录 (即含有 autoXRD 和 docker 文件夹的目录的父级)
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

echo "📝 正在为您自动生成 Dockerfile..."
cat << 'EOF' > "$PROJECT_ROOT/docker/Dockerfile"
# 1. 拉取包含 python、cuda、pytorch 的基础镜像 (据负责人要求)
FROM pytorch/pytorch:2.8.0-cuda12.6-cudnn9-runtime

# 2. 设置工作目录
WORKDIR /workspace

# 3. 将 docker 目录下的所有内容拷贝到容器的 /workspace/docker/ 目录下
COPY docker/ /workspace/docker/

# 4. 进入 docker 目录并安装依赖
RUN pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple && \
    cd /workspace/docker && pip install -e .

# 5. 为了防止大模型测试和评测脚本缺少第三方包，进行一次补充安装
RUN pip install requests urllib3 pandas openpyxl fastapi uvicorn python-multipart

# 6. 将模型文件复制到容器中
COPY our_model/Models /workspace/Models
COPY our_model/References /workspace/References
COPY our_model/run_CNN.py /workspace/run_CNN.py
COPY our_model/api_server.py /workspace/api_server.py

# 7. 创建必要的目录
RUN mkdir -p /workspace/Spectra

# 8. 暴露 API 端口
EXPOSE 8000

# 9. 启动 API 服务器
CMD ["uvicorn", "api_server:app", "--host", "0.0.0.0", "--port", "8000"]
EOF

echo "🚀 开始基于 Dockerfile 构建 xrd-test:latest 镜像..."
echo "这可能需要一些时间下载基础镜像和各种依赖库，请耐心等待。"
cd "$PROJECT_ROOT"

# 使用 docker build 命令进行构建，上下文设为项目根目录以包含 our_model 文件夹
docker build -t xrd-test:latest -t xrd-platform:v1.0 -f docker/Dockerfile .

# 检查执行结果
if [ $? -eq 0 ]; then
    echo "================================================="
    echo "✅ 镜像 xrd-test:latest 构建成功！"
    echo "现在您可以直接运行项目中的测试和评测脚本了。"
    echo "================================================="
else
    echo "❌ 镜像构建失败，请向上查看日志报错信息。"
    exit 1
fi
